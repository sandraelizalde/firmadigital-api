// ---------------------------
// Prisma Schema completo
// ---------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------
// ENUMS GENERALES
// ---------------------------
enum IdentificationType {
  CEDULA
  RUC
}

enum TypeClient {
  PERSONA_NATURAL_SIN_RUC
  PERSONA_NATURAL_CON_RUC
  PERSONA_JURIDICA
}

enum SignatureStatus {
  COMPLETED
  PENDING
  REJECTED
  FAILED
  ANNULLED
}

enum RechargeMethod {
  CARD // Tarjeta crédito/débito
  TRANSFER // Transferencia bancaria
  MANUAL // Recarga manual por admin
}

enum RechargeStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum MovementType {
  INCOME
  EXPENSE
  ADJUSTMENT
  CREDIT
}

enum Role {
  ADMIN
  DISTRIBUTOR
}

enum PaymentMethod {
  BALANCE
  CREDIT
}

enum SignatureProvider {
  ENEXT
  UANATACA
}

// ---------------------------
// DISTRIBUIDORES
// ---------------------------
model Distributor {
  id                     String             @id @default(cuid())
  firstName              String?
  lastName               String?
  socialReason           String?
  identificationType     IdentificationType
  identification         String             @unique
  password               String
  email                  String             @unique
  address                String
  city                   String             @default("QUITO")
  phone                  String
  createdBy              String? // Admin que registró
  createdByName          String?
  active                 Boolean            @default(false)
  balance                Int                @default(0) // Saldo actual del distribuidor en centavos
  contractSignedUrl      String? // URL del contrato firmado
  identificationFrontUrl String?
  identificationBackUrl  String?

  planPrices         DistributorPlanPrice[]
  signatureRequests  SignatureRequest[]
  recargas           Recharge[]
  distributorCredits DistributorCredit[]
  creditCutoffs      CreditCutoff[]
  accountMovements   AccountMovement[]
  billingInfo        BillingInfo?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------
// FACTURACIÓN
// ---------------------------
model BillingInfo {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String      @unique

  useDistributorData Boolean             @default(true)
  socialReason       String?
  identificationType IdentificationType?
  identification     String?
  email              String?
  phone              String?
  address            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------
// PLANES
// ---------------------------
model Plan {
  id                          String  @id @default(cuid())
  perfilNaturalEnext          String? @unique
  perfilJuridicoEnext         String? @unique
  perfilNaturalUanataca       String? @unique
  perfilJuridicoUanataca      String? @unique
  perfilNaturalTokenUanataca  String? @unique
  perfilJuridicoTokenUanataca String? @unique

  basePrice    Int // Precio base/sugerido en centavos
  duration     String
  durationType String // 'D', 'M', 'MS', 'Y', 'YS'

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributorPlanPrices DistributorPlanPrice[]
  signatureRequests     SignatureRequest[]
}

// ---------------------------
// ASIGNACIÓN DE PRECIOS POR DISTRIBUIDOR
// ---------------------------
// Cada distribuidor tiene precios personalizados para cada plan
model DistributorPlanPrice {
  id            String      @id @default(cuid())
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  planId        String
  plan          Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)

  customPrice      Int // Precio personalizado en centavos
  customPricePromo Int? // Precio promo personalizado en centavos (opcional)

  promoStartDate DateTime? // Fecha de inicio de la promoción
  promoEndDate   DateTime? // Fecha de fin de la promoción

  isActive Boolean @default(true)

  createdBy         String? // Admin que asignó el precio
  createdByName     String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  signatureRequests SignatureRequest[]

  @@unique([distributorId, planId])
  @@index([distributorId])
  @@index([planId])
  @@index([isActive])
}

// ---------------------------
// SOLICITUDES DE FIRMA
// ---------------------------
model SignatureRequest {
  id             String @id @default(cuid())
  numero_tramite String @unique

  distributorPlanPriceId String
  distributorPlanPrice   DistributorPlanPrice @relation(fields: [distributorPlanPriceId], references: [id])

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  perfil_firma       String
  nombres            String
  apellidos          String
  cedula             String
  correo             String
  codigo_dactilar    String
  celular            String
  provincia          String
  ciudad             String
  parroquia          String
  direccion          String
  dateOfBirth        DateTime        @db.Timestamptz(6)
  foto_frontal       String
  foto_posterior     String
  video_face         String?
  pdf_sri            String?
  nombramiento       String?
  razon_social       String?
  rep_legal          String?
  cargo              String?
  pais               String          @default("ECUADOR")
  clavefirma         String
  ruc                String?
  tipo_envio         String
  status             SignatureStatus @default(PENDING)
  providerCode       String?
  providerMessage    String?
  activeNotification Boolean         @default(true)
  priceCharged       Int             @default(0) // Precio cobrado al distribuidor en centavos
  paymentMethod      PaymentMethod   @default(BALANCE) // Método de pago utilizado
  annulledBy         String? // Nombre del admin que anuló la firma
  annulledNote       String? // Nota/motivo de la anulación
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  distributor        Distributor?    @relation(fields: [distributorId], references: [id])
  distributorId      String?

  provider SignatureProvider @default(ENEXT)

  @@index([distributorId, createdAt])
  @@index([planId])
}

// ---------------------------
// RECARGAS DE DISTRIBUIDOR
// ---------------------------
model Recharge {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String

  method          RechargeMethod
  requestedAmount Int // Monto solicitado en centavos
  creditedAmount  Int? // Monto acreditado en centavos
  commission      Int? // Comisión en centavos
  status          RechargeStatus @default(PENDING)
  approvedBy      String?
  adminNote       String?

  paymentReference String?
  transferDate     DateTime?
  receiptFile      String?
  numberReceipt    String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountMovements AccountMovement[]
}

// ----------------------------
// CREDITOS DE DISTRIBUIDOR
// ----------------------------
model DistributorCredit {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String

  creditDays Int     @default(2) // Días de crédito asignados (ej: 2 días)
  isActive   Boolean @default(true) // Si el crédito está activo
  isBlocked  Boolean @default(false) // Si está bloqueado por falta de pago
  assignedBy String? // Admin que asignó el crédito

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountMovements AccountMovement[]
  creditCutoffs    CreditCutoff[]

  @@index([distributorId, isActive])
  @@index([distributorId, isBlocked])
}

// ----------------------------
// CORTES DE CREDITO DIARIOS
// ----------------------------
model CreditCutoff {
  id            String            @id @default(cuid())
  distributor   Distributor       @relation(fields: [distributorId], references: [id])
  distributorId String
  credit        DistributorCredit @relation(fields: [creditId], references: [id])
  creditId      String

  cutoffDate        DateTime // Fecha del corte (día que se generó)
  paymentDueDate    DateTime // Fecha límite de pago (cutoffDate + creditDays)
  amountUsed        Int      @default(0) // Monto usado ese día en centavos
  amountPaid        Int      @default(0) // Monto pagado de este corte en centavos
  isPaid            Boolean  @default(false) // Si está completamente pagado
  isOverdue         Boolean  @default(false) // Si venció y no se pagó
  signaturesCount   Int      @default(0) // Cantidad de firmas emitidas ese día
  signaturesDetails String? // JSON con IDs de las firmas (opcional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([creditId, cutoffDate])
  @@index([distributorId, cutoffDate])
  @@index([creditId, isPaid])
  @@index([paymentDueDate, isPaid])
}

// ---------------------------
// ESTADO DE CUENTA
// ---------------------------
model AccountMovement {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String

  type         MovementType
  detail       String
  amount       Int // Monto en centavos
  balanceAfter Int // Balance después del movimiento en centavos
  rechargeId   String? // Si aplica a una recarga
  signatureId  String? // Si aplica a una firma
  adminName    String? // Si ajuste manual
  note         String? // Comentarios opcionales

  createdAt           DateTime           @default(now())
  recharge            Recharge?          @relation(fields: [rechargeId], references: [id])
  distributorCredit   DistributorCredit? @relation(fields: [distributorCreditId], references: [id])
  distributorCreditId String?

  @@index([signatureId])
}

// ---------------------------
// PUBLICIDAD
// ---------------------------
model Advertisement {
  id        String  @id @default(cuid())
  imageUrl  String // URL de la imagen guardada
  isActive  Boolean @default(true)
  createdBy String? // Admin que creó la publicidad

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

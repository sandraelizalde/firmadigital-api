// ---------------------------
// Prisma Schema completo
// ---------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------
// ENUMS GENERALES
// ---------------------------
enum IdentificationType {
  CEDULA
  RUC
}

enum TypeClient {
  PERSONA_NATURAL_SIN_RUC
  PERSONA_NATURAL_CON_RUC
  PERSONA_JURIDICA
}

enum SignatureStatus {
  COMPLETED
  PENDING
  FAILED
}

enum RechargeMethod {
  CARD // Tarjeta crédito/débito
  TRANSFER // Transferencia bancaria
}

enum RechargeStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
}

enum MovementType {
  INCOME
  EXPENSE
  ADJUSTMENT
}

enum Role {
  ADMIN
  DISTRIBUTOR
}

// ---------------------------
// DISTRIBUIDORES
// ---------------------------
model Distributor {
  id                 String             @id @default(cuid())
  firstName          String?
  lastName           String?
  socialReason       String?
  identificationType IdentificationType
  identification     String             @unique
  password           String
  email              String             @unique
  address            String
  phone              String
  createdBy          String? // Admin que registró
  createdByName      String?
  active             Boolean            @default(true)

  planPrices        DistributorPlanPrice[]
  signatureRequests SignatureRequest[]
  recargas          Recharge[]
  accountMovements  AccountMovement[]
  billingInfo       BillingInfo?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------
// FACTURACIÓN
// ---------------------------
model BillingInfo {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String      @unique

  useDistributorData Boolean             @default(true)
  socialReason       String?
  identificationType IdentificationType?
  identification     String?
  email              String?
  phone              String?
  address            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------
// PLANES
// ---------------------------
model Plan {
  id                  String       @id @default(cuid())
  perfil              String       @unique
  basePrice           Float // Precio base/sugerido (referencia)
  duration            String
  durationType        String // 'D', 'M', 'MS', 'Y', 'YS'
  basePricePromo      Float? // Precio promo base/sugerido
  durationPromo       String?
  isPromo             Boolean      @default(false)
  eligibleClientsType TypeClient[] @default([PERSONA_NATURAL_SIN_RUC, PERSONA_NATURAL_CON_RUC])
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  signatureRequests     SignatureRequest[]
  distributorPlanPrices DistributorPlanPrice[]
}

// ---------------------------
// ASIGNACIÓN DE PRECIOS POR DISTRIBUIDOR
// ---------------------------
// Cada distribuidor tiene precios personalizados para cada plan
model DistributorPlanPrice {
  id            String      @id @default(cuid())
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  planId        String
  plan          Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)

  customPrice      Float // Precio personalizado para este distribuidor
  customPricePromo Float? // Precio promo personalizado (opcional)
  isActive         Boolean @default(true)

  createdBy     String? // Admin que asignó el precio
  createdByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([distributorId, planId])
  @@index([distributorId])
  @@index([planId])
  @@index([isActive])
}

// ---------------------------
// SOLICITUDES DE FIRMA
// ---------------------------
model SignatureRequest {
  id                 String          @id @default(cuid())
  numero_tramite     String          @unique
  perfil_firma       String
  perfilFirma        Plan            @relation(fields: [perfil_firma], references: [perfil])
  nombres            String
  apellidos          String
  cedula             String
  correo             String
  codigo_dactilar    String
  celular            String
  provincia          String
  ciudad             String
  parroquia          String
  direccion          String
  dateOfBirth        DateTime        @db.Timestamptz(6)
  foto_frontal       String
  foto_posterior     String
  foto_selfie        String
  video_face         String?
  pdf_sri            String?
  nombramiento       String?
  razon_social       String?
  rep_legal          String?
  cargo              String?
  pais               String          @default("ECUADOR")
  clavefirma         String
  ruc                String?
  tipo_envio         String
  status             SignatureStatus @default(PENDING)
  providerCode       String?
  providerMessage    String?
  activeNotification Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  distributor        Distributor?    @relation(fields: [distributorId], references: [id])
  distributorId      String?
}

// ---------------------------
// RECARGAS DE DISTRIBUIDOR
// ---------------------------
model Recharge {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String

  method          RechargeMethod
  requestedAmount Float
  creditedAmount  Float?
  commission      Float?
  status          RechargeStatus @default(PENDING)
  adminId         String?
  adminNote       String?

  paymentReference String?
  transferDate     DateTime?
  receiptFile      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountMovements AccountMovement[]
}

// ---------------------------
// ESTADO DE CUENTA
// ---------------------------
model AccountMovement {
  id            String      @id @default(cuid())
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  distributorId String

  type         MovementType
  detail       String
  amount       Float
  balanceAfter Float
  rechargeId   String? // Si aplica a una recarga
  signatureId  String? // Si aplica a una firma
  adminId      String? // Si ajuste manual
  note         String? // Comentarios opcionales

  createdAt DateTime  @default(now())
  recharge  Recharge? @relation(fields: [rechargeId], references: [id])
}

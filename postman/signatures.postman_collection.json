{
  "info": {
    "name": "Signatures API - Nexus",
    "_postman_id": "f9b3d3b0-0000-4000-8000-000000000001",
    "description": "Colección para API de firmas digitales (endpoints de `signatures`), incluye requests para Distributor y Admin. Variables: `baseUrl`, `token`, `signatureId`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "signatureId", "value": "clx1234567890" },
    { "key": "page", "value": "1" },
    { "key": "limit", "value": "10" }
  ],
  "item": [
    {
      "name": "Distributor",
      "item": [
        {
          "name": "Create Natural Signature (multipart/form-data)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "nombres", "value": "LUIS XAVIER", "type": "text" },
                { "key": "apellidos", "value": "GONZALEZ JIMENEZ", "type": "text" },
                { "key": "cedula", "value": "1752549467", "type": "text" },
                { "key": "codigo_dactilar", "value": "V43I4444", "type": "text" },
                { "key": "correo", "value": "luisg@solucionesnexus.com", "type": "text" },
                { "key": "provincia", "value": "PICHINCHA", "type": "text" },
                { "key": "ciudad", "value": "QUITO", "type": "text" },
                { "key": "parroquia", "value": "IÑAQUITO", "type": "text" },
                { "key": "direccion", "value": "QUITUS COLONIAL", "type": "text" },
                { "key": "celular", "value": "0990602199", "type": "text" },
                { "key": "clavefirma", "value": "GONZALEZ1752", "type": "text" },
                { "key": "foto_frontal", "value": "<base64_string>", "type": "text" },
                { "key": "foto_posterior", "value": "<base64_string>", "type": "text" },
                { "key": "perfil_firma", "value": "PN-001", "type": "text" },
                { "key": "dateOfBirth", "value": "1990-05-15", "type": "text" },
                { "key": "ruc", "value": "1752549467001", "type": "text" },
                { "key": "video_face", "type": "file", "src": ["/path/to/video.mp4"] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/signatures/natural"
            }
          }
        },
        {
          "name": "Create Juridical Signature (multipart/form-data)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "nombres", "value": "LUIS XAVIER", "type": "text" },
                { "key": "apellidos", "value": "GONZALEZ JIMENEZ", "type": "text" },
                { "key": "cedula", "value": "1752549467", "type": "text" },
                { "key": "codigo_dactilar", "value": "V43I4444", "type": "text" },
                { "key": "correo", "value": "luisg@solucionesnexus.com", "type": "text" },
                { "key": "provincia", "value": "PICHINCHA", "type": "text" },
                { "key": "ciudad", "value": "QUITO", "type": "text" },
                { "key": "parroquia", "value": "IÑAQUITO", "type": "text" },
                { "key": "direccion", "value": "QUITUS COLONIAL", "type": "text" },
                { "key": "celular", "value": "0990602199", "type": "text" },
                { "key": "clavefirma", "value": "GONZALEZ1752", "type": "text" },
                { "key": "foto_frontal", "value": "<base64_string>", "type": "text" },
                { "key": "foto_posterior", "value": "<base64_string>", "type": "text" },
                { "key": "perfil_firma", "value": "PJ-003", "type": "text" },
                { "key": "dateOfBirth", "value": "1990-05-15", "type": "text" },
                { "key": "ruc", "value": "1752549467001", "type": "text" },
                { "key": "razon_social", "value": "DISTRIBUIDORA GONZALEZ S.A.", "type": "text" },
                { "key": "rep_legal", "value": "LUIS XAVIER GONZALEZ JIMENEZ", "type": "text" },
                { "key": "cargo", "value": "GERENTE GENERAL", "type": "text" },
                { "key": "pdfSriBase64", "value": "<base64_string>", "type": "text" },
                { "key": "nombramientoBase64", "value": "<base64_string>", "type": "text" },
                { "key": "video_face", "type": "file", "src": ["/path/to/video.mp4"] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/signatures/juridica"
            }
          }
        },
        {
          "name": "Get Signature (unique)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/unique?id={{signatureId}}",
              "query": [
                { "key": "id", "value": "{{signatureId}}" }
              ]
            }
          }
        },
        {
          "name": "Get All Signatures (paginated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/all?page={{page}}&limit={{limit}}",
              "query": [
                { "key": "page", "value": "{{page}}" },
                { "key": "limit", "value": "{{limit}}" }
              ]
            }
          }
        },
        {
          "name": "Validate Email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/validate-email?email=test@example.com",
              "query": [
                { "key": "email", "value": "test@example.com" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Signatures (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/admin/all?page={{page}}&limit={{limit}}&status=ALL",
              "query": [
                { "key": "page", "value": "{{page}}" },
                { "key": "limit", "value": "{{limit}}" },
                { "key": "status", "value": "ALL" }
              ]
            }
          }
        },
        {
          "name": "Get Signature (Admin unique)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/signatures/admin/unique?id={{signatureId}}",
              "query": [
                { "key": "id", "value": "{{signatureId}}" }
              ]
            }
          }
        },
        {
          "name": "Annul Signature (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signatureId\": \"{{signatureId}}\",\n  \"generateRefund\": true,\n  \"note\": \"Anulación por prueba\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures/admin/annul"
            }
          }
        },
        {
          "name": "Approve Juridical Signature (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signatureId\": \"{{signatureId}}\",\n  \"note\": \"Aprobación manual\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/signatures/admin/approve"
            }
          }
        }
      ]
    }
  ]
}
